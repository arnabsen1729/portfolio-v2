---
import BaseLayout from './BaseLayout.astro';
import TableOfContents from '@/components/TableOfContents.astro';
import TagPill from '@/components/TagPill.astro';
import JsonLd from '@/components/JsonLd.astro';
import ShareButton from '@/components/ShareButton.astro';
import { readingTime } from '@/utils/readingTime';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface AdjacentPost {
  slug: string;
  title: string;
}

interface Props {
  title: string;
  dek?: string;
  date: Date;
  tags: string[];
  headings: Heading[];
  body: string;
  readingTimeOverride?: number;
  ogImage?: string;
  numberedSections?: boolean;
  newerPost?: AdjacentPost;
  olderPost?: AdjacentPost;
}

const {
  title,
  dek,
  date,
  tags,
  headings,
  body,
  readingTimeOverride,
  ogImage,
  numberedSections = false,
  newerPost,
  olderPost,
} = Astro.props;
const base = import.meta.env.BASE_URL;

const minutes = readingTime(body, readingTimeOverride);
const dateLabel = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const postURL = new URL(Astro.url.pathname, Astro.site).toString();
const postImageURL = new URL(ogImage ?? `${base}og/home.png`, Astro.site).toString();
const postSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description: dek,
  image: postImageURL,
  datePublished: date.toISOString(),
  keywords: tags.join(', '),
  mainEntityOfPage: { '@type': 'WebPage', '@id': postURL },
  author: {
    '@type': 'Person',
    name: 'Arnab Sen',
    url: new URL(base, Astro.site).toString(),
  },
};
---

<BaseLayout title={title} description={dek} ogImage={ogImage}>
  <JsonLd data={postSchema} />
  <div id="reading-progress"></div>
  <div class="page-grid post-page">
    <article class="content">
      <header class="post-header">
        <h1>{title}</h1>
        {dek && <p class="post-dek">{dek}</p>}
        <div class="post-card-meta">
          <span class="meta">{dateLabel} · {minutes} min read</span>
          {tags.map((tag) => <TagPill tag={tag} />)}
          <ShareButton label="Share" />
        </div>
      </header>
      <div class:list={['post-content', { 'numbered-sections': numberedSections }]}>
        <slot />
      </div>
      <div class="post-share-footer">
        <ShareButton label="Share this post" />
      </div>
      {
        (newerPost || olderPost) && (
          <>
            <p class="meta post-nav-hint">j/k: older/newer</p>
            <nav class="post-adjacent-nav" aria-label="Adjacent posts">
              {newerPost ? (
                <a href={`${base}blog/${newerPost.slug}`} data-nav="newer">
                  <span class="meta">← Newer</span>
                  <span>{newerPost.title}</span>
                </a>
              ) : (
                <span />
              )}
              {olderPost ? (
                <a href={`${base}blog/${olderPost.slug}`} data-nav="older" class="align-right">
                  <span class="meta">Older →</span>
                  <span>{olderPost.title}</span>
                </a>
              ) : (
                <span />
              )}
            </nav>
          </>
        )
      }
    </article>
    <aside class="rail">
      <TableOfContents headings={headings} />
    </aside>
  </div>
</BaseLayout>

<script is:inline define:vars={{ base, newerHref: newerPost && `${base}blog/${newerPost.slug}`, olderHref: olderPost && `${base}blog/${olderPost.slug}` }}>
  function initPostNavKeys() {
    function isTypingTarget(target) {
      const tag = target?.tagName;
      return tag === 'INPUT' || tag === 'TEXTAREA' || target?.isContentEditable;
    }
    function onKeydown(e) {
      if (e.metaKey || e.ctrlKey || e.altKey || isTypingTarget(e.target)) return;
      if (document.querySelector('dialog[open]')) return;
      if (e.key === 'j' && newerHref) {
        window.location.href = newerHref;
      } else if (e.key === 'k' && olderHref) {
        window.location.href = olderHref;
      }
    }
    document.addEventListener('keydown', onKeydown);
  }
  initPostNavKeys();
</script>

<script>
  function initReadingProgress() {
    const bar = document.getElementById('reading-progress');
    if (!bar) return;
    const onScroll = () => {
      const scrollTop = window.scrollY;
      const docHeight = document.documentElement.scrollHeight - window.innerHeight;
      const pct = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0;
      bar.style.width = `${Math.min(100, Math.max(0, pct))}%`;
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }
  initReadingProgress();
  document.addEventListener('astro:after-swap', initReadingProgress);
</script>

<style>
  .post-dek {
    font-size: 1.15rem;
    color: var(--ink-soft);
    margin: 0.25em 0 1em;
    font-family: var(--font-serif);
  }
  .post-header {
    margin-bottom: 2.5rem;
    border-bottom: 1px solid var(--hairline);
    padding-bottom: 1.5rem;
  }
  /* Zero the h1's UA default top margin so it starts flush with the top of
     .content — this is what lets the sticky TOC in .rail (which has no
     equivalent top margin) line up with the h1 baseline instead of sitting
     visibly higher. */
  .post-header h1 {
    margin-top: 0;
  }
  .post-content :global(p) {
    margin: 1.25em 0;
  }

  .post-share-footer {
    display: flex;
    justify-content: center;
    margin-top: 3rem;
  }
  .post-share-footer + .post-nav-hint {
    margin-top: 2rem;
  }
  .post-nav-hint {
    text-align: center;
    margin: 3rem 0 0;
  }
  .post-adjacent-nav {
    display: flex;
    justify-content: space-between;
    gap: 1.5rem;
    margin-top: 0.75rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--hairline);
  }
  .post-adjacent-nav a {
    display: flex;
    flex-direction: column;
    gap: 0.3em;
    text-decoration: none;
    color: var(--ink);
    max-width: 45%;
  }
  .post-adjacent-nav a.align-right {
    text-align: right;
    align-items: flex-end;
  }
  .post-adjacent-nav a:hover span:last-child {
    color: var(--oxblood);
  }
  .post-adjacent-nav .meta {
    color: var(--slate);
  }
</style>
