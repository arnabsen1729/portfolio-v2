---
import '@fontsource-variable/ibm-plex-sans';
import '@fontsource/ibm-plex-mono/400.css';
import '@fontsource/ibm-plex-mono/500.css';
import '@/styles/global.css';
import { ClientRouter } from 'astro:transitions';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = 'Arnab Sen — writing on distributed systems, CS theory, math, and other things.',
  ogImage,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = ogImage
  ? new URL(ogImage, Astro.site).toString()
  : new URL(`${import.meta.env.BASE_URL}og-default.png`, Astro.site).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <link rel="canonical" href={canonicalURL} />
    <meta name="generator" content={Astro.generator} />

    <title>{title} · Arnab Sen</title>
    <meta name="description" content={description} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:url" content={canonicalURL} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <ClientRouter />

    <!-- Set theme before paint to avoid flash of wrong theme -->
    <script is:inline>
      (function () {
        const stored = localStorage.getItem('theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const isDark = stored ? stored === 'dark' : prefersDark;
        if (isDark) document.documentElement.classList.add('dark');
      })();
    </script>

    <script>
      // ClientRouter's swap replaces <html>'s attributes with the incoming
      // page's server-rendered ones, which never carry the client-only
      // `dark` class — so every soft navigation silently reset the theme
      // to light. Reapply it to the incoming document before the swap.
      function applyStoredTheme(doc: Document) {
        const stored = localStorage.getItem('theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const isDark = stored ? stored === 'dark' : prefersDark;
        doc.documentElement.classList.toggle('dark', isDark);
      }
      document.addEventListener('astro:before-swap', (event) => applyStoredTheme(event.newDocument));
    </script>
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to content</a>
    <Header />
    <main id="main-content">
      <slot />
    </main>
    <Footer />

    <script>
      // Add copy buttons to all code blocks
      const COPY_ICON =
        '<svg class="icon-copy" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>';
      const CHECK_ICON =
        '<svg class="icon-check" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>';
      function initCodeCopyButtons() {
        document.querySelectorAll('pre').forEach((pre) => {
          if (pre.querySelector('.copy-button')) return;
          const button = document.createElement('button');
          button.className = 'copy-button';
          button.type = 'button';
          button.setAttribute('aria-label', 'Copy code');
          button.innerHTML = COPY_ICON + CHECK_ICON;
          button.addEventListener('click', async () => {
            const code = pre.querySelector('code')?.textContent ?? '';
            await navigator.clipboard.writeText(code);
            button.classList.add('copied');
            button.setAttribute('aria-label', 'Copied');
            setTimeout(() => {
              button.classList.remove('copied');
              button.setAttribute('aria-label', 'Copy code');
            }, 1500);
          });
          pre.appendChild(button);
        });
      }
      initCodeCopyButtons();
      document.addEventListener('astro:after-swap', initCodeCopyButtons);
    </script>

    <script is:inline define:vars={{ homeHref: import.meta.env.BASE_URL }}>
      // "g" then "h" (within 600ms) navigates home, vim-style chord.
      // Guarded against re-registration: this is:inline script re-executes
      // on every ClientRouter soft navigation, which would otherwise stack
      // a fresh duplicate `keydown` listener on `document` each time.
      function initHomeChord() {
        let awaitingHomeChord = false;
        let chordTimer;
        function isTypingTarget(target) {
          const tag = target?.tagName;
          return tag === 'INPUT' || tag === 'TEXTAREA' || target?.isContentEditable;
        }
        document.addEventListener('keydown', (e) => {
          if (e.metaKey || e.ctrlKey || e.altKey || isTypingTarget(e.target)) return;
          if (document.querySelector('dialog[open]')) return;
          if (awaitingHomeChord) {
            awaitingHomeChord = false;
            clearTimeout(chordTimer);
            if (e.key === 'h') window.location.href = homeHref;
            return;
          }
          if (e.key === 'g') {
            awaitingHomeChord = true;
            chordTimer = setTimeout(() => (awaitingHomeChord = false), 600);
          }
        });
      }
      if (!window.__homeChordInit) {
        window.__homeChordInit = true;
        initHomeChord();
      }
    </script>
  </body>
</html>

<style>
  .skip-link {
    position: absolute;
    left: -9999px;
    top: 0;
    background: var(--paper);
    color: var(--ink);
    padding: 0.75em 1.25em;
    z-index: 1000;
    border: 1px solid var(--hairline);
  }
  .skip-link:focus {
    left: 1rem;
    top: 1rem;
  }
</style>
