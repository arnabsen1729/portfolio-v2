---
import TagPill from './TagPill.astro';
import { readingTime } from '@/utils/readingTime';

interface Props {
  slug: string;
  title: string;
  dek?: string;
  date: Date;
  tags: string[];
  body: string;
  readingTimeOverride?: number;
  variant?: 'full' | 'compact';
}

const {
  slug,
  title,
  dek,
  date,
  tags,
  body,
  readingTimeOverride,
  variant = 'full',
} = Astro.props;
const minutes = readingTime(body, readingTimeOverride);
const dateLabel = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class:list={['post-card', { 'post-card-compact': variant === 'compact' }]}>
  <h2 class="post-card-title">
    <a href={`${import.meta.env.BASE_URL}blog/${slug}`}>{title}</a>
  </h2>
  {
    variant === 'full' ? (
      <>
        {dek && <p class="post-card-dek">{dek}</p>}
        <div class="post-card-meta">
          <span class="meta post-card-meta-item">
            {dateLabel} · {minutes} min read
          </span>
          {tags.map((tag) => <TagPill tag={tag} />)}
        </div>
      </>
    ) : (
      <span class="meta post-card-compact-date">{dateLabel}</span>
    )
  }
</article>

<style>
  .post-card-meta-item {
    color: var(--ink-soft);
  }

  /* ---------- Compact variant (homepage) ---------- */
  /* Static single-line row: title left, date right, no hover mechanism —
     avoids the layout shift a hover-reveal would cause when sweeping the list. */
  .post-card-compact {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
  }
  .post-card-compact .post-card-title {
    font-size: 1.05rem;
    margin: 0;
  }
  .post-card-compact-date {
    white-space: nowrap;
    color: var(--ink-soft);
    flex-shrink: 0;
  }
</style>
