---
interface Props {
  size?: number;
  class?: string;
}

const { size = 96, class: className } = Astro.props;

// Three marked points on the ring, evenly offset, alluding to nodes placed
// on a consistent-hash ring — a nod to the site's most-read post.
const points = [18, 140, 260];
const ticks = Array.from({ length: 12 }, (_, i) => i * 30);

// Signature interaction: a "key" drops onto the ring and walks clockwise to
// the next node, illustrating consistent hashing's core rule. Start just
// past the last node so the walk clears empty ring space before landing
// exactly on points[0].
const keyStartAngle = 300;
const keyEndAngle = 378;
---

<svg
  class:list={['hash-ring', className]}
  width={size}
  height={size}
  viewBox="0 0 160 160"
  fill="none"
  aria-hidden="true"
  data-key-start={keyStartAngle}
  data-key-end={keyEndAngle}
>
  <g class="hash-ring-rotor">
    <circle cx="80" cy="80" r="62" stroke="var(--ring-stroke)" stroke-width="1.5" />
    {
      ticks.map((deg) => (
        <line
          x1="80"
          y1="14"
          x2="80"
          y2="20"
          stroke="var(--ring-stroke)"
          stroke-width="1.5"
          transform={`rotate(${deg} 80 80)`}
        />
      ))
    }
    {
      points.map((deg, i) => (
        <circle
          cx="80"
          cy="18"
          r="4"
          fill="var(--oxblood)"
          transform={`rotate(${deg} 80 80)`}
          class:list={['hash-ring-node', { 'hash-ring-target': i === 0 }]}
        />
      ))
    }
  </g>
  <g class="hash-ring-key-rotor" style={`transform: rotate(${keyStartAngle}deg)`}>
    <circle class="hash-ring-key" cx="80" cy="18" r="3" fill="var(--slate)" />
  </g>
</svg>

<style>
  .hash-ring {
    display: block;
    flex-shrink: 0;
  }

  @media (prefers-reduced-motion: no-preference) {
    .hash-ring-rotor {
      transform-origin: 80px 80px;
      animation: hash-ring-spin 90s linear infinite;
    }
  }

  @keyframes hash-ring-spin {
    from {
      transform: rotate(0deg);
    }
    to {
      transform: rotate(360deg);
    }
  }

  /* ---------- Signature interaction: key walks clockwise to its node ---------- */
  .hash-ring-key-rotor {
    transform-origin: 80px 80px;
    transition: transform 900ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  .hash-ring-key {
    opacity: 0;
    transition: opacity 200ms ease;
  }
  .hash-ring.is-active .hash-ring-key {
    opacity: 1;
  }
  .hash-ring-node {
    transition:
      r 250ms ease,
      opacity 250ms ease;
  }
  .hash-ring.is-landed .hash-ring-target {
    r: 5.5;
  }

  @media (prefers-reduced-motion: reduce) {
    .hash-ring-key-rotor {
      transition: none;
    }
  }
</style>

<script>
  // Signature interaction: a key drops onto the ring and walks clockwise to
  // land on the next node, mirroring the "next node clockwise" rule from
  // the consistent-hashing post. Plays once — on hover for pointer devices,
  // on first scroll-into-view otherwise.
  function initHashRing() {
    document.querySelectorAll<SVGSVGElement>('.hash-ring').forEach((ring) => {
      if (ring.dataset.hashRingInit) return;
      ring.dataset.hashRingInit = 'true';

      const keyRotor = ring.querySelector<SVGGElement>('.hash-ring-key-rotor');
      if (!keyRotor) return;
      const endAngle = Number(ring.dataset.keyEnd);
      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      let played = false;
      const play = () => {
        if (played) return;
        played = true;
        ring.classList.add('is-active');
        if (reduceMotion) {
          keyRotor.style.transform = `rotate(${endAngle}deg)`;
          ring.classList.add('is-landed');
          return;
        }
        requestAnimationFrame(() => {
          keyRotor.style.transform = `rotate(${endAngle}deg)`;
        });
        window.setTimeout(() => ring.classList.add('is-landed'), 950);
      };

      if (window.matchMedia('(hover: hover)').matches) {
        ring.addEventListener('mouseenter', play, { once: true });
      } else {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                play();
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.6 }
        );
        observer.observe(ring);
      }
    });
  }

  initHashRing();
  document.addEventListener('astro:after-swap', initHashRing);
</script>
