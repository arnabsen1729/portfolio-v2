---
import { quotes } from '@/content/quotes';
---

<div class="quote-block" data-quote-block>
  <canvas class="quote-canvas" aria-hidden="true"></canvas>
  <figure class="quote-figure">
    {
      quotes.map((q, i) => (
        <blockquote class="quote-item" data-quote-index={i} hidden>
          <p>“{q.text}”</p>
          <figcaption class="meta">
            — {q.author}
            {q.attribution && <span class="quote-src">, {q.attribution}</span>}
          </figcaption>
        </blockquote>
      ))
    }
  </figure>
</div>

<script is:inline data-astro-rerun>
  // Picks a random quote to unhide. Runs pre-paint on hard loads (no flash,
  // since every item starts `hidden`) and re-runs on every soft navigation
  // so each visit surfaces a different quote. `data-astro-rerun` is required
  // because this script's content is byte-identical on every page — without
  // it, ClientRouter's script dedup (keyed on textContent) only ever runs it
  // once for the whole session and skips it on subsequent navigations.
  (function () {
    const items = document.querySelectorAll('[data-quote-block] .quote-item');
    if (!items.length) return;
    items.forEach((item) => (item.hidden = true));
    items[Math.floor(Math.random() * items.length)].hidden = false;
  })();
</script>

<script>
  // Faint drifting dots behind the quote — a subtle particle effect, not an
  // attention-grabbing one. Mirrors HashRing's init-guard / reduced-motion /
  // astro:after-swap pattern.
  function initQuoteParticles() {
    const block = document.querySelector<HTMLElement>('[data-quote-block]');
    const canvas = block?.querySelector<HTMLCanvasElement>('.quote-canvas');
    if (!block || !canvas || canvas.dataset.particlesInit) return;
    canvas.dataset.particlesInit = 'true';

    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const DOT_COUNT = 28;

    interface Dot {
      x: number;
      y: number;
      vx: number;
      vy: number;
      r: number;
      a: number;
    }

    let dots: Dot[] = [];
    let width = 0;
    let height = 0;
    let dpr = 1;
    let dotColor = getComputedStyle(canvas).color;
    let raf = 0;

    function seed() {
      dots = Array.from({ length: DOT_COUNT }, () => ({
        x: Math.random() * width,
        y: Math.random() * height,
        vx: (Math.random() - 0.5) * 0.15,
        vy: (Math.random() - 0.5) * 0.15,
        r: 0.8 + Math.random() * 1.2,
        a: 0.06 + Math.random() * 0.08,
      }));
    }

    function resize() {
      dpr = Math.min(window.devicePixelRatio || 1, 2);
      const rect = block!.getBoundingClientRect();
      width = rect.width;
      height = rect.height;
      canvas!.width = Math.round(width * dpr);
      canvas!.height = Math.round(height * dpr);
      ctx!.setTransform(dpr, 0, 0, dpr, 0, 0);
      if (!dots.length) seed();
    }

    function draw() {
      ctx!.clearRect(0, 0, width, height);
      ctx!.fillStyle = dotColor;
      for (const d of dots) {
        ctx!.globalAlpha = d.a;
        ctx!.beginPath();
        ctx!.arc(d.x, d.y, d.r, 0, Math.PI * 2);
        ctx!.fill();
      }
      ctx!.globalAlpha = 1;
    }

    function tick() {
      for (const d of dots) {
        d.x = (d.x + d.vx + width) % width;
        d.y = (d.y + d.vy + height) % height;
      }
      draw();
      raf = requestAnimationFrame(tick);
    }

    function start() {
      if (!raf && !reduceMotion) raf = requestAnimationFrame(tick);
    }
    function stop() {
      cancelAnimationFrame(raf);
      raf = 0;
    }

    resize();
    draw(); // static frame — the only rendering that happens under reduced motion

    const io = new IntersectionObserver(([entry]) => {
      if (entry.isIntersecting) start();
      else stop();
    });
    io.observe(block);

    const ro = new ResizeObserver(resize);
    ro.observe(block);

    // Dot color follows the `--ink` custom property; recompute when the
    // dark-mode class toggles on <html>.
    const mo = new MutationObserver(() => {
      dotColor = getComputedStyle(canvas!).color;
    });
    mo.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });

    document.addEventListener('astro:before-swap', function cleanup() {
      stop();
      io.disconnect();
      ro.disconnect();
      mo.disconnect();
      document.removeEventListener('astro:before-swap', cleanup);
    });
  }

  initQuoteParticles();
  document.addEventListener('astro:after-swap', initQuoteParticles);
</script>

<style>
  .quote-block {
    position: relative;
    padding: 2.5rem 0;
    margin-bottom: 1.25rem;
  }
  .quote-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    color: var(--ink);
    pointer-events: none;
  }
  .quote-figure {
    position: relative;
    margin: 0;
    text-align: center;
  }
  .quote-item p {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.15rem;
    line-height: 1.5;
    color: var(--ink-soft);
    margin: 0 0 0.6em;
  }
  .quote-item figcaption {
    font-style: normal;
  }
  .quote-src {
    color: var(--slate);
  }
</style>
