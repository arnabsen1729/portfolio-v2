---
import Icon from './icons/Icon.astro';

const base = import.meta.env.BASE_URL;
---

<button class="search-trigger" id="search-trigger" type="button" aria-label="Search">
  <Icon name="search" size={14} /> search <kbd class="search-kbd">⌘K</kbd>
</button>

<dialog id="search-dialog" class="search-dialog">
  <div id="search-container"></div>
</dialog>

<script>
  function initSearch() {
    const trigger = document.getElementById('search-trigger');
    const dialog = document.getElementById('search-dialog') as HTMLDialogElement | null;
    if (!trigger || !dialog) return;

    let loaded = false;

    function loadPagefind(): Promise<void> {
      if (loaded) return Promise.resolve();
      loaded = true;
      // These assets only exist after `astro build && pagefind --site dist` —
      // load via a plain <script src> tag (not a bundler-resolved dynamic
      // import) since the file doesn't exist at Vite build time.
      return new Promise((resolve, reject) => {
        const script = document.createElement('script');
        script.src = `${import.meta.env.BASE_URL}pagefind/pagefind-ui.js`;
        script.onload = () => {
          const PagefindUI = (window as any).PagefindUI;
          if (PagefindUI) {
            new PagefindUI({ element: '#search-container', showSubResults: true });
          }
          resolve();
        };
        script.onerror = reject;
        document.head.appendChild(script);
      });
    }

    function openDialog() {
      dialog?.showModal();
      loadPagefind().then(() => {
        dialog?.querySelector<HTMLInputElement>('input')?.focus();
      });
    }

    trigger.addEventListener('click', openDialog);
    dialog.addEventListener('click', (e) => {
      if (e.target === dialog) dialog.close();
    });
    document.addEventListener('keydown', (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
        e.preventDefault();
        openDialog();
        return;
      }
      if (e.key === '/' && !e.metaKey && !e.ctrlKey && !e.altKey) {
        const target = e.target as HTMLElement | null;
        const tag = target?.tagName;
        if (tag === 'INPUT' || tag === 'TEXTAREA' || target?.isContentEditable) return;
        e.preventDefault();
        openDialog();
      }
    });
  }

  initSearch();
  document.addEventListener('astro:after-swap', initSearch);
</script>

<link rel="stylesheet" href={`${base}pagefind/pagefind-ui.css`} />

<style>
  .search-trigger {
    display: inline-flex;
    align-items: center;
    gap: 0.4em;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    background: none;
    border: 1px solid var(--hairline);
    border-radius: 6px;
    padding: 0.3em 0.7em;
    color: var(--ink-soft);
    cursor: pointer;
    transition:
      border-color 150ms ease,
      color 150ms ease;
  }
  .search-trigger:hover {
    border-color: var(--slate);
    color: var(--ink);
  }
  .search-kbd {
    font-family: var(--font-mono);
    font-size: 0.75em;
    color: var(--ink-soft);
    border: 1px solid var(--hairline);
    border-radius: 4px;
    padding: 0.1em 0.4em;
  }
  @media (pointer: coarse) {
    .search-kbd {
      display: none;
    }
  }

  .search-dialog {
    width: min(600px, 90vw);
    max-height: 70vh;
    border: 1px solid var(--hairline);
    border-radius: 8px;
    padding: 1.5rem;
    background: var(--paper);
    color: var(--ink);
  }
  .search-dialog::backdrop {
    background: rgba(0, 0, 0, 0.4);
  }

  :global(.pagefind-ui__search-input) {
    font-family: var(--font-body);
  }
  :global(.pagefind-ui) {
    --pagefind-ui-primary: var(--oxblood);
    --pagefind-ui-text: var(--ink);
    --pagefind-ui-background: var(--paper);
    --pagefind-ui-border: var(--hairline);
    --pagefind-ui-tag: var(--code-bg);
    font-family: var(--font-body);
  }
</style>
