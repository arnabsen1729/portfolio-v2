---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import TagPill from '@/components/TagPill.astro';

const papers = (await getCollection('papershelf')).sort((a, b) => b.data.year - a.data.year);
---

<BaseLayout title="Papershelf" description="Papers I've read and notes on them.">
  <div class="simple-page">
    <h1>Papershelf</h1>
    <p class="intro-dek">Papers I've read, with a tl;dr and my own notes.</p>
    <div class="paper-grid">
      {
        papers.map((paper) => (
          <article class="paper-card">
            <h2 class="paper-title">
              {paper.data.link ? (
                <a href={paper.data.link} target="_blank" rel="noopener noreferrer">
                  {paper.data.title}
                </a>
              ) : (
                paper.data.title
              )}
            </h2>
            <p class="meta">
              {paper.data.authors.join(', ')} · {paper.data.year}
            </p>
            <p class="paper-tldr">{paper.data.tldr}</p>
            <div class="post-card-meta">
              {paper.data.tags.map((tag) => (
                <TagPill tag={tag} />
              ))}
            </div>
          </article>
        ))
      }
    </div>
  </div>
</BaseLayout>

<style>
  .intro-dek {
    color: var(--ink-soft);
    font-size: 1.1rem;
    margin-bottom: 2.5rem;
  }
  .paper-grid {
    display: grid;
    gap: 1.5rem;
  }
  .paper-card {
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--hairline);
  }
  .paper-title {
    font-size: 1.25rem;
    margin: 0 0 0.15em;
  }
  .paper-title a {
    color: var(--ink);
    text-decoration: none;
  }
  .paper-title a:hover {
    color: var(--oxblood);
  }
  .paper-tldr {
    margin: 0.6em 0;
  }
</style>
