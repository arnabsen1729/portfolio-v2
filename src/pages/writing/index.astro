---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import PostCard from '@/components/PostCard.astro';
import TagPill from '@/components/TagPill.astro';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const tagCounts = new Map<string, number>();
posts.forEach((post) => post.data.tags.forEach((tag) => tagCounts.set(tag, (tagCounts.get(tag) ?? 0) + 1)));
const frequentTags = Array.from(tagCounts.entries())
  .filter(([, count]) => count >= 2)
  .sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]));
---

<BaseLayout title="Writing">
  <div class="simple-page">
    <h1>Writing</h1>
    <p class="intro-dek">
      Notes on distributed systems, CS theory, math, and whatever else is occupying my head this
      week.
    </p>
    {
      frequentTags.length > 0 && (
        <div class="tag-summary">
          {frequentTags.map(([tag, count]) => (
            <TagPill tag={tag} count={count} />
          ))}
        </div>
      )
    }
    <div class="post-list">
      {
        posts.map((post) => (
          <PostCard
            slug={post.id}
            title={post.data.title}
            dek={post.data.dek}
            date={post.data.date}
            tags={post.data.tags}
            body={post.body ?? ''}
            readingTimeOverride={post.data.readingTimeOverride}
          />
        ))
      }
    </div>
  </div>
</BaseLayout>

<style>
  .intro-dek {
    color: var(--ink-soft);
    font-size: 1.1rem;
    margin-bottom: 1.5rem;
  }
  .tag-summary {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 2.5rem;
  }
</style>
