---
import type { GetStaticPaths, Page } from 'astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import PostCard from '@/components/PostCard.astro';
import Pagination from '@/components/Pagination.astro';
import { introCopy } from '@/content/site';

export const getStaticPaths = (async ({ paginate }) => {
  const allPosts = await getCollection('blog', ({ data }) => !data.draft);
  const posts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
  return paginate(posts, { pageSize: 5 });
}) satisfies GetStaticPaths;

interface Props {
  page: Page<CollectionEntry<'blog'>>;
}

const { page } = Astro.props as Props;
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Arnab Sen">
  <div class="simple-page homepage">
    <div class="homepage-gradient" aria-hidden="true">
      <span class="blob blob-1"></span>
      <span class="blob blob-2"></span>
      <span class="blob blob-3"></span>
    </div>

    <section class="intro">
      {introCopy.map((paragraph) => <p>{paragraph}</p>)}
      <div class="key-links">
        <a href="https://github.com/arnabsen" target="_blank" rel="noopener noreferrer">GitHub</a>
        <a href={`${base}resume`}>Résumé</a>
        <a href="mailto:hello@arnabsen.dev">Email</a>
        <a href={`${base}rss.xml`}>RSS</a>
      </div>
    </section>

    <hr class="section-divider" />

    <div class="post-list">
      {
        page.data.map((post, index) => (
          <div class="post-card-reveal" style={`transition-delay: ${Math.min(index, 6) * 60}ms`}>
            <PostCard
              slug={post.id}
              title={post.data.title}
              dek={post.data.dek}
              date={post.data.date}
              tags={post.data.tags}
              body={post.body ?? ''}
              readingTimeOverride={post.data.readingTimeOverride}
              variant="compact"
            />
          </div>
        ))
      }
    </div>

    <Pagination
      prevUrl={page.url.prev}
      nextUrl={page.url.next}
      currentPage={page.currentPage}
      lastPage={page.lastPage}
    />
  </div>
</BaseLayout>

<style>
  .homepage {
    position: relative;
  }

  /* ---------- Gradient background (homepage only) ---------- */
  /* Breaks out of .simple-page's narrow centered column so the blobs span
     the same full viewport width as the sticky navbar above, instead of
     being confined (and off-center) within the reading column. */
  .homepage-gradient {
    position: absolute;
    top: -2rem;
    left: 50%;
    width: 100vw;
    transform: translateX(-50%);
    height: 26rem;
    overflow: hidden;
    z-index: -1;
    pointer-events: none;
  }
  .homepage-gradient .blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(100px);
    opacity: 0.1;
  }
  .blob-1 {
    top: -4rem;
    left: 5%;
    width: 22rem;
    height: 22rem;
    background: var(--oxblood);
  }
  .blob-2 {
    top: -2rem;
    right: 8%;
    width: 18rem;
    height: 18rem;
    background: var(--slate);
  }
  .blob-3 {
    top: 6rem;
    left: 38%;
    width: 16rem;
    height: 16rem;
    background: var(--slate);
  }
  html.dark .homepage-gradient .blob {
    opacity: 0.16;
  }

  @media (prefers-reduced-motion: no-preference) {
    .blob-1 {
      animation: drift-1 26s ease-in-out infinite alternate;
    }
    .blob-2 {
      animation: drift-2 22s ease-in-out infinite alternate;
    }
    .blob-3 {
      animation: drift-3 30s ease-in-out infinite alternate;
    }
  }
  @keyframes drift-1 {
    from {
      transform: translate(0, 0);
    }
    to {
      transform: translate(1.5rem, 1rem);
    }
  }
  @keyframes drift-2 {
    from {
      transform: translate(0, 0);
    }
    to {
      transform: translate(-1.25rem, 1.5rem);
    }
  }
  @keyframes drift-3 {
    from {
      transform: translate(0, 0);
    }
    to {
      transform: translate(1rem, -1rem);
    }
  }

  /* ---------- Intro entrance ---------- */
  .intro {
    margin-bottom: 2.5rem;
  }
  .intro p {
    color: var(--ink-soft);
    font-size: 1.1rem;
  }
  .key-links {
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    margin-top: 1.25rem;
  }
  .key-links a {
    color: var(--oxblood);
    text-decoration: none;
  }
  .key-links a:hover {
    text-decoration: underline;
  }

  @media (prefers-reduced-motion: no-preference) {
    .intro {
      animation: intro-in 450ms ease-out;
    }
  }
  @keyframes intro-in {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* ---------- Divider between intro and post list ---------- */
  .section-divider {
    border: none;
    border-top: 1px solid var(--hairline);
    margin: 0 0 2rem;
  }

  /* ---------- Post card staggered reveal ---------- */
  @media (prefers-reduced-motion: no-preference) {
    .post-card-reveal {
      opacity: 0;
      transform: translateY(10px);
      transition:
        opacity 450ms ease-out,
        transform 450ms ease-out;
    }
    .post-card-reveal.in-view {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

<script>
  // Homepage-only: stagger post cards into view as they cross the viewport.
  function initHomepageCardReveal() {
    const cards = document.querySelectorAll('.post-card-reveal');
    if (!cards.length) return;

    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      cards.forEach((card) => card.classList.add('in-view'));
      return;
    }

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('in-view');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.1 }
    );
    cards.forEach((card) => observer.observe(card));
  }
  initHomepageCardReveal();
  document.addEventListener('astro:after-swap', initHomepageCardReveal);
</script>
