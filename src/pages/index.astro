---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import PostCard from '@/components/PostCard.astro';
import HashRing from '@/components/HashRing.astro';
import Icon from '@/components/icons/Icon.astro';
import JsonLd from '@/components/JsonLd.astro';
import { introCopy } from '@/content/site';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()).slice(0, 5);
const base = import.meta.env.BASE_URL;
const siteURL = new URL(base, Astro.site).toString();

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Arnab Sen',
  url: siteURL,
  jobTitle: 'Software Engineer',
  worksFor: { '@type': 'Organization', name: 'Google' },
  sameAs: [
    'https://github.com/arnabsen1729',
    'https://x.com/arnabsen1729',
    'https://linkedin.com/in/arnabsen1729',
  ],
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Arnab Sen',
  url: siteURL,
};
---

<BaseLayout title="Arnab Sen">
  <JsonLd data={personSchema} />
  <JsonLd data={websiteSchema} />
  <div class="simple-page homepage">
    <section class="intro">
      <div class="intro-text">
        <h1 class="visually-hidden">Arnab Sen</h1>
        {introCopy.map((paragraph, i) => <p class:list={{ 'intro-lede': i === 0 }}>{paragraph}</p>)}
        <p>
          Before Google I interned at <a
            href="https://www.gmetri.com/"
            target="_blank"
            rel="noopener noreferrer">GMetri</a
          > and <a
            href="https://www.cypherock.com/"
            target="_blank"
            rel="noopener noreferrer">Cypherock</a
          >, and spent a summer contributing to <a href={`${base}blog/summer-of-bitcoin-21`}
            >Bitcoin Core</a
          > through Summer of Bitcoin. More on the <a href={`${base}about`}>about page</a>.
        </p>
        <div class="key-links">
          <a href="https://github.com/arnabsen1729" target="_blank" rel="noopener noreferrer">
            <Icon name="github" size={15} /> GitHub
          </a>
          <a href="https://x.com/arnabsen1729" target="_blank" rel="noopener noreferrer">
            <Icon name="x" size={15} /> X
          </a>
          <a href={`${base}resume`}>
            <Icon name="file-text" size={15} /> Résumé
          </a>
          <a href="mailto:arnabsen1729@gmail.com">
            <Icon name="mail" size={15} /> Email
          </a>
          <a href={`${base}rss.xml`}>
            <Icon name="rss" size={15} /> RSS
          </a>
        </div>
      </div>
      <HashRing class="intro-ring" size={96} />
    </section>

    <hr class="section-divider" />

    <div class="section-heading">
      <h2 class="eyebrow">Writing</h2>
      <a href={`${base}writing`} class="section-heading-link">See all →</a>
    </div>

    <div class="post-list">
      {
        posts.map((post, index) => (
          <div class="post-card-reveal" style={`transition-delay: ${Math.min(index, 6) * 60}ms`}>
            <PostCard
              slug={post.id}
              title={post.data.title}
              dek={post.data.dek}
              date={post.data.date}
              tags={post.data.tags}
              body={post.body ?? ''}
              readingTimeOverride={post.data.readingTimeOverride}
              variant="compact"
            />
          </div>
        ))
      }
    </div>
  </div>
</BaseLayout>

<style>
  .homepage {
    position: relative;
  }

  /* ---------- Intro entrance ---------- */
  .intro {
    display: grid;
    grid-template-columns: 1fr;
    align-items: start;
    gap: 1.5rem;
    margin-bottom: 2.5rem;
  }
  .intro-text h1 {
    margin: 0 0 0.75rem;
  }
  .intro-text p {
    color: var(--ink-soft);
    font-size: 1.1rem;
  }
  .intro-text p.intro-lede {
    color: var(--ink);
    font-size: 1.3rem;
    line-height: 1.5;
  }
  .intro-ring {
    justify-self: start;
    opacity: 0.9;
  }
  @media (min-width: 640px) {
    .intro {
      grid-template-columns: 1fr auto;
    }
    .intro-ring {
      justify-self: end;
    }
  }
  .key-links {
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    margin-top: 1.25rem;
  }
  .key-links a {
    display: inline-flex;
    align-items: center;
    gap: 0.4em;
    color: var(--oxblood);
    text-decoration: none;
    transition: opacity 150ms ease;
  }
  .key-links a:hover {
    opacity: 0.75;
    text-decoration: underline;
  }

  @media (prefers-reduced-motion: no-preference) {
    .intro {
      animation: intro-in 450ms ease-out;
    }
  }
  @keyframes intro-in {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* ---------- Divider between intro and post list ---------- */
  .section-divider {
    border: none;
    border-top: 1px solid var(--hairline);
    margin: 0 0 2rem;
  }

  /* ---------- "Writing" section heading ---------- */
  .section-heading {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.25rem;
  }
  .section-heading h2 {
    margin: 0;
  }
  .section-heading-link {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--oxblood);
    text-decoration: none;
    white-space: nowrap;
    transition: opacity 150ms ease;
  }
  .section-heading-link:hover {
    opacity: 0.75;
    text-decoration: underline;
  }

  /* ---------- Post card staggered reveal ---------- */
  @media (prefers-reduced-motion: no-preference) {
    .post-card-reveal {
      opacity: 0;
      transform: translateY(10px);
      transition:
        opacity 450ms ease-out,
        transform 450ms ease-out;
    }
    .post-card-reveal.in-view {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

<script>
  // Homepage-only: stagger post cards into view as they cross the viewport.
  function initHomepageCardReveal() {
    const cards = document.querySelectorAll('.post-card-reveal');
    if (!cards.length) return;

    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      cards.forEach((card) => card.classList.add('in-view'));
      return;
    }

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('in-view');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.1 }
    );
    cards.forEach((card) => observer.observe(card));
  }
  initHomepageCardReveal();
  document.addEventListener('astro:after-swap', initHomepageCardReveal);
</script>
